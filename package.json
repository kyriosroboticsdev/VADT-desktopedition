{
  "name": "vadt",
  "version": "1.0.0",
  "description": "VEX Autonomous Detection Tool — desktop scouting app",
  "author": "Kyrio",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.kyrio.vadt",
    "productName": "VADT",
    "copyright": "Copyright © 2025 Kyrio",
    "files": [
      "app.js",
      "main.js",
      "preload.js",
      "index.html",
      "notebook.html",
      "config.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vadt_cv.py",
        "to": "vadt_cv.py"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VADT"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.sports"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Sports"
    },
    "publish": {
      "provider": "github",
      "owner": "kyrio",
      "repo": "vadt"
    }
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "git": "^0.1.5"
  }
}
